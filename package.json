{
  "name": "clawrap",
  "version": "1.0.0",
  "description": "Clawrap - Electron wrapper for OpenClaw web terminal",
  "main": "dist/main/index.js",
  "author": "OpenClaw <openclaw@example.com>",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/lightconsen/clawrap.git"
  },
  "scripts": {
    "dev": "NODE_ENV=development npm run build:ts && mkdir -p dist/renderer/setup dist/renderer/install dist/renderer/terminal && cp src/renderer/setup/*.html src/renderer/setup/*.css dist/renderer/setup/ 2>/dev/null; cp src/renderer/install/*.html src/renderer/install/*.css dist/renderer/install/ 2>/dev/null; cp src/renderer/terminal/*.html src/renderer/terminal/*.png dist/renderer/terminal/ 2>/dev/null; NODE_ENV=development electron .",
    "build:ts": "tsc && tsc -p tsconfig.renderer.json",
    "build": "npm run build:ts && electron-builder",
    "build:mac": "npm run build:ts && electron-builder --mac",
    "build:win": "npm run build:ts && electron-builder --win",
    "build:linux": "npm run build:ts && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps",
    "build:openclaw": "bash scripts/build-standalone.sh",
    "download-node": "bash scripts/download-node.sh",
    "remove:gateway": "openclaw gateway stop 2>/dev/null; openclaw gateway uninstall 2>/dev/null; echo 'OpenClaw gateway service stopped/uninstalled'",
    "remove:openclaw": "npm uninstall -g openclaw 2>/dev/null; pnpm uninstall -g openclaw 2>/dev/null; echo 'OpenClaw npm package removed'",
    "remove:data": "read -p 'Remove all OpenClaw data (~/.openclaw)? [y/N] ' confirm && [ \"$confirm\" = \"y\" ] && rm -rf ~/.openclaw && echo 'OpenClaw data removed' || echo 'Skipped data removal'",
    "remove:config": "rm -rf ~/Library/Application\\ Support/OpenClaw && echo 'Electron config removed'",
    "clean": "rm -rf dist release node_modules/.cache",
    "remove:all": "npm run remove:gateway && npm run remove:openclaw && npm run remove:data && npm run remove:config && npm run clean && echo 'Full removal complete'"
  },
  "dependencies": {
    "electron-log": "^5.0.0",
    "electron-updater": "^6.1.0",
    "fs-extra": "^11.0.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.0.0",
    "electron": "41.0.4",
    "electron-builder": "^24.0.0",
    "typescript": "^5.3.0"
  },
  "build": {
    "appId": "com.openclaw.desktop",
    "productName": "OpenClaw",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/default-config.yaml",
        "to": "default-config.yaml"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "verifyUpdateCodeSignature": false
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        },
        {
          "target": "rpm",
          "arch": ["x64"]
        }
      ],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
