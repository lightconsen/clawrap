# OpenClaw Desktop

build/
dist/
release/
node_modules/
*.log
.DS_Store
.env
.env.local

# Compiled files in src (should only contain .ts source)
src/**/*.js
src/**/*.js.map
src/**/*.d.ts
src/**/*.d.ts.map
!src/renderer/types.d.ts
!src/renderer/assets.d.ts

# Gateway binaries (large files)
resources/gateway/*
resources/node/
!resources/gateway/.gitkeep

# Empty workspace file (not used)
pnpm-workspace.yaml

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
Thumbs.db

# Git hooks (tracked in .git-hooks/, not .git/hooks/)
.git/hooks/

# Reports
report.md
